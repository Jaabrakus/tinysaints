# Any OpenAI-compatible hosted or self-hosted endpoint.
AI_BASE_URL=https://api.moonshot.ai/v1
AI_MODEL=kimi-k2.5

# Server-side only. Use MOONSHOT_API_KEY, KIMI_API_KEY, or AI_API_KEY.
AI_API_KEY=

# Only for a trusted self-hosted endpoint that intentionally has no bearer key.
AI_ALLOW_UNAUTHENTICATED=false

# Optional protected self-hosting bridge. CORE_ROOM_SLUG must name one existing room.
# Use a narrowly scoped fine-grained GitHub token with Contents: Read and write for one repository.
CORE_ROOM_SLUG=
GITHUB_RELEASE_REPOSITORY=owner/repository
GITHUB_RELEASE_BRANCH=main
GITHUB_RELEASE_TOKEN=
